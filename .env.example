# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Auth for the judgment layer (eval, single review). Use ONE of these:
#   - Direct Anthropic API:
ANTHROPIC_API_KEY=sk-ant-...
#   - Via a bearer-auth gateway/proxy (set base_url below, and use AUTH_TOKEN
#     INSTEAD of API_KEY — setting both returns a 400):
# ANTHROPIC_AUTH_TOKEN=sk-...

# Optional: route through an Anthropic-compatible gateway/proxy.
# The SDK appends /v1/messages to this. Leave unset for the direct API.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# Optional: override the model (default: claude-opus-4-8).
# ASSURANCE_MODEL=claude-opus-4-8

# --- Phase 2 (not needed for the MVP eval) ---
# OCR — Apple Vision (macOS) needs no config: `pip install -e ".[ocr]"`.
# Tesseract fallback language data (default "kor+eng"; falls back to "eng"):
# TESSERACT_LANG=kor+eng
# MaxKB retrieval backend (optional; docker-compose.maxkb.yml). v2 logs in with
# username/password (defaults admin / MaxKB@123..).
# MAXKB_BASE_URL=http://localhost:8080
# MAXKB_USERNAME=admin
# MAXKB_PASSWORD=MaxKB@123..
# Legal grounding via korean-law-mcp (free 법제처 Open API "OC" key)
# LAW_OC=
