# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Required for the judgment layer (eval, single review).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-opus-4-8).
# ASSURANCE_MODEL=claude-opus-4-8

# --- Phase 2 (not needed for the MVP eval) ---
# OCR — Apple Vision on-device wrapper binary
# MACVIS_BIN=macvis
# MaxKB retrieval backend
# MAXKB_BASE_URL=http://localhost:8080
# MAXKB_API_KEY=
# Legal grounding via korean-law-mcp (free 법제처 Open API "OC" key)
# LAW_OC=
